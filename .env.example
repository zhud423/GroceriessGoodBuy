# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Runtime database URL used by the app itself.
# This is what Prisma Client uses during `pnpm dev`, page loads, and API requests.
# For Supabase, prefer the pooled Prisma `DATABASE_URL`.
DATABASE_URL=

# Schema management URL used by Prisma CLI commands such as `pnpm db:push`.
# `db push` means: compare `prisma/schema.prisma` with the live database, then
# apply the schema changes directly so local tables/enums/columns stay in sync.
# For Supabase, prefer the Prisma `DIRECT_URL` when that direct host is reachable.
DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Public project URL used by both browser and server clients.
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public API key used by browser-side Supabase calls.
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key with elevated privileges.
# Never expose this to the browser or commit it to a public repo.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Test Login
# -----------------------------------------------------------------------------
# Lightweight auth for prototype validation.
# Use a single JSON array so multiple test accounts are modeled as one config set.
# Wrap the JSON in single quotes to keep it readable in .env files.
TEST_LOGIN_ACCOUNTS='[{"username":"admin","password":"change-me","displayName":"管理员测试"},{"username":"buyer","password":"change-me","displayName":"采购测试"}]'

# Server-only secret used to sign app sessions.
APP_SESSION_SECRET=change-me

# Public app URL used for local redirects and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Storage
# -----------------------------------------------------------------------------
# Buckets can keep these defaults for now.
# They are used later by screenshot import and archived order images.
SUPABASE_STORAGE_BUCKET_IMPORTS=imports
SUPABASE_STORAGE_BUCKET_ORDERS=orders
SUPABASE_STORAGE_BUCKET_PRODUCTS=products

# -----------------------------------------------------------------------------
# Import / Vision Provider
# -----------------------------------------------------------------------------
# Not required to boot the current manual CRUD flow.
# Fill these when enabling screenshot import and model-based analysis.
# Volcengine Ark:
# 1. Open Ark console: https://console.volcengine.com/ark
# 2. In "权限管理 -> API Key" create a server-side API key
# 3. In "在线推理" create or select an image-capable endpoint, then copy its Endpoint ID
# 4. Paste the API key and Endpoint ID below
LLM_PROVIDER=ark

ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Accepts a Volcengine Ark Endpoint ID or a directly callable vision model ID.
ARK_VISION_MODEL=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_VISION_MODEL=
